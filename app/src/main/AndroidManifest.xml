<?xml version="1.0" encoding="utf-8"?>
<!-- The package name lives in app/build.gradle as `namespace`.
     AGP 8.x rejects a package="..." attribute here. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ================================================================== -->
    <!-- Permissions                                                          -->
    <!-- ================================================================== -->

    <!-- Downloading the blocklist + forwarding DNS queries to 8.8.8.8 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Needed to read the underlying network's real DNS servers, instead of
         hardcoding a public resolver the ISP may block. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Required on API 28+ to call startForeground() -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Required on API 34+ when foregroundServiceType="specialUse".
         VPNs don't have a dedicated foreground type, so specialUse is the
         correct choice. Sideloaded APKs don't need Play Store justification,
         but the permission declaration is still required by the OS. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- ================================================================== -->
    <!-- Application                                                          -->
    <!-- ================================================================== -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <!-- Main launcher activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- VPN service
             android:permission="android.permission.BIND_VPN_SERVICE":
               Restricts binding to the OS only (it is a signature-level
               permission). No third-party app can hijack our tunnel.
               Android also refuses to establish a VPN tunnel if this
               attribute is missing.
             android:exported="true":
               Required so the OS can discover and manage the service via
               the android.net.VpnService intent filter.
             android:foregroundServiceType="specialUse":
               Required on API 34+ for all foreground services. VPN apps
               use specialUse because there is no dedicated "vpn" type. -->
        <service
            android:name=".AdBlockVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:exported="true"
            android:foregroundServiceType="specialUse">

            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>

            <!-- Required companion to foregroundServiceType="specialUse" on API 34+.
                 Older OS versions ignore this element entirely. -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="DNS-based ad blocker using VpnService" />

        </service>

    </application>
</manifest>
