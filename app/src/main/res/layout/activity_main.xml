<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ink"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="28dp"
        android:paddingRight="28dp"
        android:paddingTop="36dp"
        android:paddingBottom="32dp">

        <!-- ============ eyebrow ============ -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="3dp"
                android:layout_height="13dp"
                android:background="@drawable/eyebrow_bar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:text="AD BLOCKER"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:letterSpacing="0.22"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ============ status ============ -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="OFF"
            android:textColor="@color/text"
            android:textSize="44sp"
            android:letterSpacing="-0.02"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:id="@+id/upstreamText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="@color/muted"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <!-- ============ counts ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:orientation="horizontal"
            android:background="@drawable/panel"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/stoppedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/amber"
                    android:textSize="30sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="STOPPED"
                    android:textColor="@color/muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.18"
                    android:fontFamily="sans-serif-condensed" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="20dp"
                android:background="@color/line" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/seenCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text"
                    android:textSize="30sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="LOOKED UP"
                    android:textColor="@color/muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.18"
                    android:fontFamily="sans-serif-condensed" />
            </LinearLayout>
        </LinearLayout>

        <!-- ============ the live feed: this app's whole point ============ -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="3dp"
                android:layout_height="11dp"
                android:background="@drawable/eyebrow_bar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:text="LIVE"
                android:textColor="@color/muted"
                android:textSize="11sp"
                android:letterSpacing="0.22"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/streamText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="200dp"
            android:text=""
            android:textSize="12sp"
            android:lineSpacingExtra="5dp"
            android:fontFamily="monospace" />

        <!-- ============ health, quiet but there ============ -->
        <TextView
            android:id="@+id/healthText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:paddingTop="12dp"
            android:text=""
            android:textColor="@color/muted"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <!-- ============ one control ============ -->
        <Button
            android:id="@+id/toggleButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/pill_filled"
            android:text="Start blocking"
            android:textColor="@color/ink"
            android:textSize="15sp"
            android:letterSpacing="0.02"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>
